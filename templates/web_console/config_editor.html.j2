{% extends "layout.html.j2" %}

{% set active_page = '/plugins/config-editor' %}

{% block title %}{{ title or 'Config Editor' }}{% endblock %}

{% block page_title %}Config Editor{% endblock %}

{% block main_class %}content-scroll{% endblock %}

{% block head_extras %}
<style>
  .row { display:flex; gap:8px; align-items:center; flex-wrap: wrap; }
  .toolbar-row { position: sticky; top: 0; z-index: 50; background: var(--bg-panel, var(--bg-card, var(--bg-header, #1a1a1a))); color: var(--text-main); padding: 12px 0; box-shadow: 0 1px 2px rgba(0,0,0,0.18); border-bottom: 1px solid var(--border-color); }
  .toolbar-row + .advisory { margin-top: 12px; }
  .row > * { margin: 0; }
  .status { margin-top: 8px; min-height: 24px; }
  .toolbar .status { margin-top: 0; min-height: 0; }
  .status .ok { color: var(--status-ok-color); }
  .status .err { color: var(--status-err-color); white-space: pre-wrap; }
  .hint { color: var(--text-muted); font-size: 12px; }
  .spacer { flex: 1; }
  .section { border:1px solid var(--border-color); padding:8px; margin:8px 0; background:var(--bg-panel); }
  .section > .legend, .config-section > .legend { display:flex; align-items:baseline; gap:8px; margin-bottom: 4px; }
  .legend .title { font-weight:600; color:var(--text-main); font-size:16px; }
  .legend .desc { color:var(--text-muted); font-size:12px; }
  .field { display:flex; gap:8px; align-items:center; margin:4px 0; }
  .field label { width: 220px; color:var(--text-main); }
  .field .help { color:var(--text-muted); font-size:12px; margin-left: 8px; }
  .field .default-hint { color:var(--text-muted); font-size:12px; margin-left: 8px; }
  .field input[type="text"], .field input[type="number"], .field select { flex:1; padding:4px; background:var(--input-bg); color:var(--input-text); border:1px solid var(--border-color); }
  .field input[type="checkbox"] { width: 16px; height: 16px; }
  .tbl-wrap { margin: 12px 0; border: 1px solid var(--border-color); border-radius: 4px; overflow: hidden; background: var(--bg-panel); }
  table.config { width:100%; border-collapse: collapse; border-spacing: 0; }
  table.config th, table.config td { padding: 10px 12px; text-align: left; border-bottom: 1px solid var(--border-color); font-size: 13px; }
  table.config th { background: var(--table-header-bg); color: var(--table-header-text); font-weight: 600; border-bottom: 1px solid var(--border-color); white-space: nowrap; text-transform: uppercase; font-size: 11px; letter-spacing: 0.5px; }
  table.config td { color: var(--text-main); }
  table.config tr:last-child td { border-bottom: none; }
  table.config tr:hover td { background: var(--table-row-hover); }
  table.config tr.editing td { background: var(--table-row-active); color: var(--text-main); }
  table.config tr.editing td:first-child { border-left: 3px solid var(--accent-color); padding-left: 9px; }
  table.config tr.inline-editor-row,
  table.config tr.inline-editor-row:hover { background: var(--bg-panel); }
  table.config tr.inline-editor-row td { padding: 0; background: var(--bg-panel); border-bottom: 1px solid var(--border-color); border-left: 3px solid var(--accent-color); }
  table.config tr.inline-editor-row:hover td,
  table.config tr.inline-editor-row td:hover { background: var(--bg-panel); }
  table.config tr.editing td { border-bottom: none; }
  table.config tr.editing + tr.inline-editor-row td { border-top: none; }
  table.config td .cell-muted { color: var(--text-muted); font-style: italic; }
  .tbl-wrap > div:last-child:not(:empty) { padding: 8px 12px; background: var(--bg-panel); border-top: 1px solid var(--border-color); }
  .inline-editor-panel { margin: 0; border: none; background: transparent; padding: 12px; padding-left: 9px; }
  .inline-editor-panel .legend { margin-top: 0; padding-left: 0; }
  .mini-btn { padding: 4px 10px; font-size: 11px; border: 1px solid var(--border-color); background: var(--btn-bg); color: var(--text-main); border-radius: 3px; cursor: pointer; margin-right: 6px; transition: all 0.2s; }
  .mini-btn.edit-toggle { min-width: 64px; text-align: center; }
  .mini-btn:hover { background: var(--btn-hover-bg); color: var(--text-main); border-color: var(--text-muted); }
  .toolbar { display:flex; gap:8px; align-items:center; }
  .req { color:var(--req-color); margin-left: 4px; font-size: 11px; }
  .subtle { color:var(--text-muted); font-size: 12px; }
  .password-helper { display:flex; flex-wrap:wrap; gap:8px; margin-top:8px; align-items:center; }
  .password-helper input[type="password"] { flex:1; min-width:200px; }
  .password-helper-status { font-size:12px; min-height:16px; color:var(--text-muted); }
  .password-helper-status.ok { color: var(--status-ok-color); }
  .password-helper-status.err { color: var(--status-err-color); }
  
  /* Section headers */
  .config-section { margin-bottom: 24px; }
  .section-header { display: flex; align-items: baseline; gap: 12px; padding-bottom: 8px; border-bottom: 1px solid var(--border-color); margin-bottom: 12px; }
  .section-header .title { font-size: 18px; font-weight: 600; color: var(--text-main); }
  .section-header .desc { font-size: 13px; color: var(--text-muted); }


  .advisory { margin-top: 6px; min-height: 20px; }
  .advisory .warn { color: var(--warn-color); }
  [data-config-section].read-only { opacity: 0.6; position: relative; }
  .read-only-note { font-size: 12px; color: var(--warn-color, #b45309); font-weight: 600; margin: 6px 0; }
  [data-config-section].read-only .tbl-wrap.locked { pointer-events: none; }
</style>
{% endblock %}

{% block content %}
<div class="row toolbar-row">
  <div class="toolbar">
    <button class="btn" id="loadBtn" title="Load current config">Load</button>
    <button class="btn" id="validateBtn" title="Validate without saving">Validate</button>
    <button class="btn" id="saveBtn" title="Save to server.yaml">Save</button>
    <div class="status" id="status"></div>
  </div>
  <div class="spacer"></div>
  
</div>
<div class="advisory" id="advisory"></div>
<div class="subtle" style="margin-top:6px">Fields marked with <span class="req">*</span> are required.</div>

<div id="formRoot">
  <div id="view-auth" class="config-view" style="display:none">

  <div class="config-section" data-config-section="authentication">
    <div class="section-header"><span class="title">Authentication</span> <span class="desc">Local users, API keys, public keys, and PAM</span></div>
    <div id="authSection">
      <div class="legend"><div class="title">Users</div><div class="desc">Basic-auth accounts</div></div>
      <div id="auth.users"></div>
      <div class="legend" style="margin-top:10px"><div class="title">API Keys</div><div class="desc">Token auth</div></div>
      <div id="auth.api_keys"></div>
      <div class="legend" style="margin-top:10px"><div class="title">Public Keys</div><div class="desc">Ed25519 keys with allowed_uses</div></div>
      <div id="auth.public_keys"></div>
      <div class="legend" style="margin-top:10px"><div class="title">PAM (System Auth)</div><div class="desc">Use UNIX accounts and groups</div></div>
      <div class="section">
      <div class="field"><label for="auth.pam.enabled">Enable PAM</label><input id="auth.pam.enabled" type="checkbox" /></div>
      <div class="field"><label for="auth.pam.service_name">Service name</label><input id="auth.pam.service_name" type="text" placeholder="login" /><span class="help">PAM service to use (e.g., login, system-auth)</span></div>
      <div class="field"><label for="auth.pam.allow_root">Allow root</label><input id="auth.pam.allow_root" type="checkbox" /><span class="help">If unchecked, root user cannot log in via PAM</span></div>
      <div class="field"><label for="auth.pam.allowed_users">Allowed users</label><input id="auth.pam.allowed_users" type="text" placeholder="comma,separated,users" /><span class="help">Optional allowlist: only these users can authenticate via PAM</span></div>
      <div class="legend" style="margin-top:10px"><div class="title">PAM Groups</div><div class="desc">Map system groups to roles</div></div>
      <div class="section">
          <div class="field"><label for="auth.pam.groups.admin_group">Admin group</label><input id="auth.pam.groups.admin_group" type="text" placeholder="openmux_admin" /></div>
          <div class="field"><label for="auth.pam.groups.write_group">Write group</label><input id="auth.pam.groups.write_group" type="text" placeholder="openmux_write" /></div>
          <div class="field"><label for="auth.pam.groups.read_group">Read group</label><input id="auth.pam.groups.read_group" type="text" placeholder="openmux_read" /></div>
      </div>
      </div>
    </div>
  </div>

  </div>

  <div id="view-setup" class="config-view">

  <div class="config-section" data-config-section="server">
    <div class="section-header"><span class="title">Server</span> <span class="desc">Server identity and description</span></div>
    <div class="section">
      <div class="field"><label for="server.id">Server ID</label><input id="server.id" type="text" /></div>
      <div class="field"><label for="server.description">Description</label><input id="server.description" type="text" /></div>
      <div class="field"><label for="server.control_socket">Control socket path</label><input id="server.control_socket" type="text" placeholder="logs/openmux.sock" /><span class="help">Unix domain socket for local CLI control (status/reload). Env override: OPENMUX_CTL_SOCK.</span></div>
      <div class="field"><label for="server.pidfile">PID file path</label><input id="server.pidfile" type="text" placeholder="logs/openmux.pid" /><span class="help">PID file used for signal-based control (HUP soft reload, USR1 full reload). Env override: OPENMUX_PIDFILE.</span></div>
    </div>
  </div>

  <div class="config-section" data-config-section="logging">
    <div class="section-header"><span class="title">Logging</span> <span class="desc">File and console logging</span></div>
    <div class="section">
      <div class="field"><label for="logging.level">Level</label>
        <select id="logging.level">
          <option value=""></option>
          <option>DEBUG</option><option>INFO</option><option>WARNING</option><option>ERROR</option><option>CRITICAL</option>
          <option>debug</option><option>info</option><option>warning</option><option>error</option><option>critical</option>
        </select>
      </div>
      <div class="field"><label for="logging.console">Console</label><input id="logging.console" type="checkbox" /></div>
      <div class="field"><label for="logging.file">File</label><input id="logging.file" type="text" /></div>
      <div class="field"><label for="logging.log_dir">Log Dir</label><input id="logging.log_dir" type="text" /></div>
      <div class="field"><label for="logging.max_log_size">Max size</label><input id="logging.max_log_size" type="number" min="0" /></div>
      <div class="field"><label for="logging.log_backup_count">Backup count</label><input id="logging.log_backup_count" type="number" min="0" /></div>
    </div>
  </div>

  </div>

  <div id="view-listeners" class="config-view" style="display:none">
  <div class="config-section" data-config-section="client_listener">
    <div class="section-header"><span class="title">Client listener</span> <span class="desc">TCP console endpoint</span></div>
    <div class="section">
      <div class="field"><label for="client_listener.enabled">Enable listener</label><input id="client_listener.enabled" type="checkbox" /></div>
      <div class="field"><label for="client_listener.host">Host</label><input id="client_listener.host" type="text" /></div>
      <div class="field"><label for="client_listener.port">Port</label><input id="client_listener.port" type="number" min="1" max="65535" /></div>
      <div class="field"><label for="client_listener.max_connections">Max connections</label><input id="client_listener.max_connections" type="number" min="1" /></div>
      <div class="field"><label for="client_listener.connection_timeout">Timeout (s)</label><input id="client_listener.connection_timeout" type="number" min="1" /></div>
    </div>
  </div>

  <div class="config-section" data-config-section="telnet_listener">
    <div class="section-header"><span class="title">Telnet listener</span> <span class="desc">Expose OpenMux ports over raw TCP</span></div>
    <div id="telnet_listener"></div>
  </div>
  </div>

  <div id="view-reload" class="config-view" style="display:none">
  <div class="config-section">
    <div class="section-header"><span class="title">Reload Actions</span> <span class="desc">Apply changes to the running server</span></div>
    <div class="section">
      <div class="field">
        <label>Soft reload</label>
        <button class="btn" id="softReloadBtn" type="button">Soft Reload</button>
        <span class="help">Reloads YAML, updates authentication (users/API keys/PAM/public keys), and reconciles Serial/Loopback/Command/TCP-initiator ports without restarting listeners.</span>
      </div>
      <div class="field">
        <label>Full reload</label>
        <button class="btn" id="fullReloadBtn" type="button">Full Reload</button>
        <span class="help">Stops and recreates adapters. Use when changing client listener, muxcon listeners/initiators, TLS, or other core settings. May briefly disconnect sessions.</span>
      </div>
      <div class="status" id="reloadStatus"></div>
    </div>
  </div>

  <div class="config-section">
    <div class="section-header"><span class="title">Guidance</span> <span class="desc">When to use what</span></div>
    <div class="section">
      <ul style="margin:0 0 0 18px; padding:0;">
        <li>Use <b>Soft Reload</b> for: Authentication updates (users/API keys/PAM), muxcon public keys, and edits to Serial/Loopback/Command/TCP-initiator ports.</li>
        <li>Use <b>Full Reload</b> for: Client listener enable/host/port changes, muxcon listeners/initiators, TLS enable/certs/TOFU settings, and other adapter-wide options.</li>
        <li>Reminder: Click <b>Save</b> first. Reload applies what’s in the active config file.</li>
      </ul>
    </div>
  </div>
  </div>

  <div id="view-ports" class="config-view" style="display:none">
  <div class="config-section" data-config-section="serial_ports">
    <div class="section-header"><span class="title">Serial ports</span> <span class="desc">Physical serial devices</span></div>
    <div id="serial_ports"></div>
  </div>

  <div class="config-section" data-config-section="loopback_ports">
    <div class="section-header"><span class="title">Loopback ports</span> <span class="desc">Software loopbacks</span></div>
    <div id="loopback_ports"></div>
  </div>

  <div class="config-section" data-config-section="command_ports">
    <div class="section-header"><span class="title">Command ports</span> <span class="desc">Process-backed ports</span></div>
    <div id="command_ports"></div>
  </div>

  <div class="config-section" data-config-section="tcp_initiator_ports">
    <div class="section-header"><span class="title">TCP initiator ports</span> <span class="desc">Outbound TCP adapters</span></div>
    <div id="tcp_initiator_ports"></div>
  </div>
  </div>

  <div id="view-muxcon" class="config-view" style="display:none">
  <div class="config-section" data-config-section="muxcon">
    <div class="section-header"><span class="title">Muxcon</span> <span class="desc">Federation and transport</span></div>
    <div class="section" id="muxcon">
      <div class="field"><label for="muxcon.node_name">Node name (deprecated)</label><input id="muxcon.node_name" type="text" /></div>
    </div>
  </div>

  <div class="config-section" data-config-section="muxcon">
    <div class="section-header"><span class="title">Listeners</span> <span class="desc">Incoming connections</span></div>
    <div id="muxcon.listeners"></div>
  </div>

  <div class="config-section" data-config-section="muxcon">
    <div class="section-header"><span class="title">Initiators</span> <span class="desc">Outgoing connections</span></div>
    <div id="muxcon.initiators"></div>
  </div>

  <div class="config-section" data-config-section="web_status">
    <div class="section-header"><span class="title">Public Keys</span> <span class="desc">Ed25519 keys for muxcon federation</span></div>
    <div id="muxcon.public_keys"></div>
  </div>

  <div class="config-section" data-config-section="web_console">
    <div class="section-header"><span class="title">Advanced</span> <span class="desc">Timing, cache, filters, auth</span></div>
    <div class="section">
      <div class="field"><label for="muxcon.heartbeat_interval">Heartbeat interval</label><input id="muxcon.heartbeat_interval" type="number" min="0" step="0.1" /></div>
      <div class="field"><label for="muxcon.mpath_primary_stale_sec">MP stale sec</label><input id="muxcon.mpath_primary_stale_sec" type="number" min="0" step="0.1" /></div>
      <div class="field"><label for="muxcon.mpath_failover_check_sec">MP check sec</label><input id="muxcon.mpath_failover_check_sec" type="number" min="0" step="0.1" /></div>
      <div class="field"><label for="muxcon.mpath_strategy">MP strategy</label><select id="muxcon.mpath_strategy"><option value=""></option><option value="best_pref">best_pref</option></select></div>
      <div class="field"><label for="muxcon.mpath_preemptive_promote">MP preemptive</label><input id="muxcon.mpath_preemptive_promote" type="checkbox" /></div>
      <div class="field"><label for="muxcon.mpath_neighbor_idle_drop_sec">MP neighbor drop</label><input id="muxcon.mpath_neighbor_idle_drop_sec" type="number" min="0" step="0.1" /></div>
      <div class="field"><label for="muxcon.federated_cache_enabled">Federated cache</label><input id="muxcon.federated_cache_enabled" type="checkbox" /></div>
      <div class="field"><label for="muxcon.federated_cache_ttl_sec">Cache TTL (s)</label><input id="muxcon.federated_cache_ttl_sec" type="number" min="0" step="0.1" /></div>
      <div class="field"><label for="muxcon.federated_cache_path">Cache path</label><input id="muxcon.federated_cache_path" type="text" /></div>
      <div class="field"><label for="muxcon.auth_required">Auth required</label><input id="muxcon.auth_required" type="checkbox" /></div>
      <div class="field"><label for="muxcon.auth_key_id">Auth key id</label><input id="muxcon.auth_key_id" type="text" /></div>
      <div class="field"><label for="muxcon.auth_private_key">Private key</label><input id="muxcon.auth_private_key" type="text" /></div>
    </div>
  </div>
  </div>

  <div id="view-setup-2" class="config-view">
  <div class="config-section" data-config-section="web_status">
    <div class="section-header"><span class="title">Web status</span> <span class="desc">Read-only status server</span></div>
    <div class="section">
      <div class="field"><label for="web_status.host">Host</label><input id="web_status.host" type="text" /></div>
      <div class="field"><label for="web_status.port">Port</label><input id="web_status.port" type="number" min="1" max="65535" /></div>
      <div class="field"><label for="web_status.enable_http_api">HTTP API</label><input id="web_status.enable_http_api" type="checkbox" /></div>
      <div class="field"><label for="web_status.cors_enable">CORS</label><input id="web_status.cors_enable" type="checkbox" /></div>
      <div class="field"><label for="web_status.enable_fault_injection">Fault injection</label><input id="web_status.enable_fault_injection" type="checkbox" /></div>
    </div>
  </div>

  <div class="config-section" data-config-section="web_console">
    <div class="section-header"><span class="title">Web console</span> <span class="desc">Admin UI and WS console</span></div>
    <div class="section">
      <div class="field"><label for="web_console.host">Host</label><input id="web_console.host" type="text" /></div>
      <div class="field"><label for="web_console.port">Port</label><input id="web_console.port" type="number" min="1" max="65535" /></div>
      <div class="field"><label for="web_console.ssl_port">SSL Port</label><input id="web_console.ssl_port" type="number" min="1" max="65535" /></div>
      <div class="field"><label for="web_console.base_path">Base path</label><input id="web_console.base_path" type="text" placeholder="/" /></div>
      <div class="field"><label for="web_console.respect_forwarded_prefix">Respect X-Forwarded-Prefix</label><input id="web_console.respect_forwarded_prefix" type="checkbox" /></div>
      <div class="field"><label for="web_console.enable_ui">Enable UI</label><input id="web_console.enable_ui" type="checkbox" /></div>
      <div class="field"><label for="web_console.realm">Realm</label><input id="web_console.realm" type="text" /></div>
      <div class="field"><label for="web_console.static_dir">Static dir</label><input id="web_console.static_dir" type="text" /></div>
      <div class="field"><label for="web_console.template_dir">Template dir</label><input id="web_console.template_dir" type="text" /></div>
      <div class="field"><label for="web_console.session_ttl_seconds">Session TTL (s)</label><input id="web_console.session_ttl_seconds" type="number" min="0" /></div>
      <div class="legend"><div class="title">Login throttling</div><div class="desc">Limit repeated failed logins per IP</div></div>
      <div class="field"><label for="web_console.login_throttle_max_attempts">Max attempts</label><input id="web_console.login_throttle_max_attempts" type="number" min="1" /></div>
      <div class="field"><label for="web_console.login_throttle_window_seconds">Window (s)</label><input id="web_console.login_throttle_window_seconds" type="number" min="1" /></div>
      <div class="field"><label for="web_console.login_throttle_lock_seconds">Lock duration (s)</label><input id="web_console.login_throttle_lock_seconds" type="number" min="1" /></div>
      <div class="legend"><div class="title">Probes</div><div class="desc">/healthz /livez /readyz</div></div>
      <div class="field"><label for="web_console.enable_probes">Enable probes</label><input id="web_console.enable_probes" type="checkbox" /></div>
      <div class="field"><label for="web_console.probes_include_details">Include details</label><input id="web_console.probes_include_details" type="checkbox" /></div>
      <div class="legend"><div class="title">TLS</div><div class="desc">Optional HTTPS</div></div>
      <div class="field"><label for="web_console.use_tls">Use TLS</label><input id="web_console.use_tls" type="checkbox" /></div>
      <div class="field"><label for="web_console.ssl_cert">SSL cert</label><input id="web_console.ssl_cert" type="text" /></div>
      <div class="field"><label for="web_console.ssl_key">SSL key</label><input id="web_console.ssl_key" type="text" /></div>
      <div class="field"><label for="web_console.tls_autogen">Autogenerate cert</label><input id="web_console.tls_autogen" type="checkbox" /></div>
      <div class="field"><label for="web_console.tls_dir">TLS dir</label><input id="web_console.tls_dir" type="text" /></div>
    </div>
    <div class="legend"><div class="title">Plugins</div><div class="desc">Web plugin modules to load</div></div>
    <div id="web_console.plugins"></div>
  </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
  (function(){
        const status = document.getElementById('status');
        const BTN = (id) => document.getElementById(id);
        let csrf = null;
        let current = {};
        const INITIAL_WRITABLE_SECTIONS = {{ writable_sections|default([])|tojson|safe }};
        const INITIAL_WRITABLE_ENFORCED = {{ writable_enforced|default(False)|tojson|safe }};
        let writableSections = new Set(Array.isArray(INITIAL_WRITABLE_SECTIONS) ? INITIAL_WRITABLE_SECTIONS : []);
        let writableEnforced = !!INITIAL_WRITABLE_ENFORCED;
        // Ensure a single open editor globally
        let activeEditorEl = null;
        let activeEditorCleanup = null;
        let activeEditorValidate = null; // returns true if OK, false if missing required; also shows inline error
        let activeEditorSave = null; // programmatically save current editor if valid

        let isDirty = false;
        let isPopulating = false;
        function markDirty(){ if(!isPopulating){ isDirty=true; updateStatus(); } }
        function markClean(){ isDirty=false; updateStatus(); }
        function updateStatus(){
          const btn = document.getElementById('saveBtn');
          if(btn){
             if(isDirty) btn.textContent = 'Save *';
             else btn.textContent = 'Save';
          }
        }
        window.addEventListener('beforeunload', (e)=>{
